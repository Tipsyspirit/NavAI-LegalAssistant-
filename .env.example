# NavAI Configuration
# This file is used automatically — no changes needed for default setup.
# Copy to .env and edit only if you want to customise paths or models.

# Path to embedding model (downloaded automatically on first run)
NAVAI_EMBED_MODEL=./models/bge_model

# Ollama LLM model
NAVAI_LLM_MODEL=llama3.2:3b

# ChromaDB persistent storage
NAVAI_CHROMA_PATH=./chroma_db
NAVAI_COLLECTION=navai_docs

# Pre-built knowledge base chunks
NAVAI_CHUNKS_FILE=./data/chunks_improved.json

# Retrieval settings
NAVAI_TOP_K=3
NAVAI_TIMEOUT=30.0
NAVAI_CHUNK_WORDS=500
NAVAI_CHUNK_OVERLAP=50

# OCR settings (optional — only needed for scanned PDFs)
# TESSERACT_CMD=tesseract
# OCR_LANGUAGES=hin+eng
# OCR_DPI=300

# Cohere reranker (optional — leave blank to skip)
# COHERE_API_KEY=
# COHERE_TOP_N=3
